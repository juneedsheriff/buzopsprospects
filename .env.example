NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# Supabase (required for Submit)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# One-time table setup (npm run db:setup) — from Supabase -> Database -> Connection string
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or set only the database password:
# SUPABASE_DB_PASSWORD=your_database_password

# Optional: connect to your BuzOps backend for email lookup
# BUZOPS_API_BASE_URL=https://your-buzops-api.example.com
# BUZOPS_VERIFY_EMAIL_PATH=/UserMember/VerifyUserByEmail
# BUZOPS_API_AUTH_TOKEN=
